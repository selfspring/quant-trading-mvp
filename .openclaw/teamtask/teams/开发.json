  "workflow": {
    "name": "标准9步协作流程",
    "description": "PM→Architect→并行开发→Review→QA→部署",
    "requiredRoles": [
      "pm",
      "architect"
    ],
    "steps": [
      {
        "step": 1,
        "role": "pm",
        "action": "产出 PRD 和用户故事",
        "output": "requirements.md, user-stories.md"
      },
      {
        "step": 2,
        "role": "architect",
        "action": "架构评审与技术方案",
        "output": "architecture.md, api-spec.md",
        "feedback_loop": "pm"
      },
      {
        "step": 3,
        "roles": [
          "frontend",
          "backend"
        ],
        "action": "并行开发",
        "parallel": true,
        "output": "代码实现"
      },
      {
        "step": 4,
        "role": "code-artisan",
        "action": "代码审查与优化",
        "output": "review-report.md"
      },
      {
        "step": 5,
        "role": "qa",
        "action": "测试",
        "output": "test-report.md"
      },
      {
        "step": 6,
        "roles": [
          "pm",
          "qa"
        ],
        "action": "共同确认可交付",
        "output": "sign-off.md"
      },
      {
        "step": 7,
        "role": "devops",
        "action": "测试环境部署",
        "output": "deployment-log.md"
      },
      {
        "step": 8,
        "role": "_user",
        "action": "用户确认测试环境",
        "output": "user-feedback.md"
      },
      {
        "step": 9,
        "role": "devops",
        "action": "生产环境部署",
        "output": "production-log.md"
      }
    ]
  },
