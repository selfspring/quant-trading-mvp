      "responsibilities": [
        "API 文档撰写",
        "用户手册编写",
        "README 维护",
        "知识库管理"
      ]
    }
  },
  "modelTypes": {
    "strongest": {
      "label": "Strongest Reasoning",
      "description": "最强推理能力 — Architect, DevOps, Security",
      "example": "claude-opus-4.6"
    },
    "code": {
      "label": "Code Specialized",
      "description": "代码生成优化 — Frontend, Backend, Code Artisan",
      "example": "gpt-5.3-codex"
    },
    "balanced": {
      "label": "Balanced",
      "description": "创作与分析平衡 — PM, QA, Tech Writer",
      "example": "claude-sonnet-4.6"
    },
    "fast": {
      "label": "Fast",
      "description": "响应快成本低 — 简单任务、草稿",
      "example": "claude-haiku-4.5"
    },
    "longContext": {
      "label": "Long Context",
      "description": "大上下文窗口 — 跨文件分析、长文档",
      "example": "gemini-2.5-pro"
    }
  },
  "workflowTemplates": {
    "standard-9step": {
      "name": "标准9步协作流程",
      "description": "PM→Architect→并行开发→Review→QA→部署",
      "requiredRoles": ["pm", "architect"],
      "steps": [
        { "step": 1, "role": "pm", "action": "产出 PRD 和用户故事", "output": "SPEC.md, user-stories.md", "contextReset": true, "handoffOutput": "handoff-1-pm.md" },
        { "step": 2, "role": "architect", "action": "架构评审与技术方案", "output": "architecture.md, api-spec.md", "feedback_loop": "pm", "contextReset": true, "handoffOutput": "handoff-2-architect.md" },
        { "step": 3, "roles": ["frontend", "backend"], "action": "并行开发", "parallel": true, "output": "代码实现", "evaluator": "qa", "iterateUntil": { "minScore": 7, "maxIterations": 5 }, "contextReset": true, "handoffOutput": "handoff-3-{role}.md" },
        { "step": 4, "role": "code-artisan", "action": "代码审查与优化", "output": "review-report.md", "contextReset": true, "handoffOutput": "handoff-4-code-artisan.md" },
        { "step": 5, "role": "qa", "action": "集成测试", "output": "test-report.md", "contextReset": true, "handoffOutput": "handoff-5-qa.md" },
        { "step": 6, "roles": ["pm", "qa"], "action": "共同确认可交付", "output": "sign-off.md", "contextReset": false },
        { "step": 7, "role": "devops", "action": "测试环境部署", "output": "deployment-log.md", "contextReset": true, "handoffOutput": "handoff-7-devops.md" },
        { "step": 8, "role": "_user", "action": "用户确认测试环境", "output": "user-feedback.md", "contextReset": false },
        { "step": 9, "role": "devops", "action": "生产环境部署", "output": "production-log.md", "contextReset": false }
      ]
    },
    "quick-3step": {
      "name": "快速3步流程",
      "description": "适合小型任务：开发→审查→部署",
      "requiredRoles": [],
      "steps": [
        { "step": 1, "roles": ["frontend", "backend"], "action": "直接开发", "parallel": true, "output": "代码实现", "evaluator": "qa", "iterateUntil": { "minScore": 7, "maxIterations": 3 }, "contextReset": true, "handoffOutput": "handoff-1-{role}.md" },
        { "step": 2, "role": "code-artisan", "action": "代码审查", "output": "review-report.md", "optional": true, "contextReset": true, "handoffOutput": "handoff-2-code-artisan.md" },
        { "step": 3, "role": "devops", "action": "部署", "output": "deployment-log.md", "optional": true, "contextReset": false }
      ]
    },
    "fullstack-solo": {
      "name": "全栈独角兽",
      "description": "2-3人精简团队，一人多角色",
      "requiredRoles": [],
      "steps": [
        { "step": 1, "role": "pm", "action": "需求与设计", "output": "SPEC.md", "contextReset": true, "handoffOutput": "handoff-1-pm.md" },
        { "step": 2, "roles": ["frontend", "backend"], "action": "全栈开发", "parallel": true, "output": "代码实现", "evaluator": "qa", "iterateUntil": { "minScore": 7, "maxIterations": 5 }, "contextReset": true, "handoffOutput": "handoff-2-{role}.md" },
        { "step": 3, "role": "qa", "action": "测试与部署", "output": "test-report.md", "contextReset": false }
      ]
    },
    "custom": {
      "name": "自定义流程",
      "description": "完全自定义协作步骤",
      "requiredRoles": [],
      "steps": []
    }
  }
}
